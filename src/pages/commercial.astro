---
import "../styles/base.css";
import "../styles/nav.css";
import "../styles/nav-offscreen.css";
import "../styles/images.css";
import "../styles/films.css";
import "../styles/tours.css";
import "../styles/modal-film.css";
import "../styles/contact.css";

import About from "../components/commercial/About.astro";
import Analytics from "../components/commercial/Analytics.astro";
import Contact from "../components/commercial/Contact.astro";
import Films from "../components/commercial/Films.astro";
import Hero from "../components/commercial/Hero.astro";
import Images from "../components/commercial/Images.astro";
import Nav from "../components/commercial/Nav.astro";
import Tours from "../components/commercial/Tours.astro";
import PageHead from "../components/shared/PageHead.astro";

const heroSlides = [
  {
    src: "walkeweg_b",
    alt: "Photorealistic architectural visualization by Scuares",
    logoTheme: "light",
  },
  {
    src: "puglia",
    alt: "Photorealistic architectural visualization by Scuares",
    logoTheme: "dark",
  },
  {
    src: "walkeweg_a",
    alt: "Photorealistic architectural visualization by Scuares",
    logoTheme: "light",
  },
  {
    src: "basel_b",
    alt: "Photorealistic architectural visualization by Scuares",
    logoTheme: "light",
  },
  {
    src: "basel_a",
    alt: "Photorealistic architectural visualization by Scuares",
    logoTheme: "light",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <PageHead
      title="Scuares-Architectural Visualization. 3D Rendering"
      description="Architectural Visualization studio that produces high-end photorealistic 3D renderings for architecture and real estate. Images, Videos, 360 Virtual Tours, CG Animations, Walkthroughs, Cinemagraphs "
    />

    <script>
      import "../js/appCommercial.js";
    </script>

    <Analytics />
  </head>
  <body class="commercial-page">
    <Nav />

    <main id="page-content">
      <Hero slides={heroSlides} />
      <About />
      <Films />
      <Images />
      <Tours />
      <Contact />
    </main>

    <Contact variant="modal" />
  </body>
</html>
