            class="img-lazy"
            alt="Photorealistic exterior 3D Rendering of a modern house made of stone in a Greek Island. Luxury villa with sea view and beautiful landscape. Still CG Image produced by Scuares, an architectural visualization studio"
          />
          <Credit hidden={true} author="West Valley" project="Villas in Antiparos" />
        </div>
      </section>

      <!-- forest -->
      <section class="images-one snap">
        <div class="img-full">
          <img
            src="/images/pixel.jpg"
            data-src="forest"
            width="1778"
            height="1000"
            style="aspect-ratio: 1778 / 1000"
            class="img-lazy"
            alt="Photorealistic exterior 3D Rendering of a modern contemporary house inside a forest designed by JM Designs. Luxury glass villa surrounded by trees. Still CG Image produced by Scuares, an architectural visualization studio"
          />
          <Credit author="JM Designs" project="Forest House" />
        </div>
      </section>

      <!-- basel -->
      <section class="images-two snap">
        <div class="img-full">
          <img
            src="/images/pixel.jpg"
            data-src="basel_a"
            width="1000"
            height="1000"
            style="aspect-ratio: 1 / 1"
            class="img-lazy"
            alt="Photorealistic exterior 3D Rendering of a modern multifamily housing building made of metal and concrete in Basel designed by Parabase Architects. Project for an architectural competition. Still CG Image produced by Scuares, an architectural visualization studio"
          />
          <Credit
