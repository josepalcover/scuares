            src="/images/pixel.jpg"
            data-src="antiparos_b"
            width="1000"
            height="1000"
            style="aspect-ratio: 1 / 1"
            class="img-lazy"
            alt="Photorealistic exterior 3D Rendering of a modern house made of stone in a Greek Island. Luxury villa with sea view and beautiful landscape. Real Estate residential project. Still CG Image produced by Scuares, an architectural visualization studio"
          />
