---
import "../styles/base.css";
import "../styles/nav.css";
import "../styles/nav-offscreen.css";
import "../styles/images.css";
import "../styles/films.css";
import "../styles/tours.css";
import "../styles/modal-film.css";
import "../styles/contact.css";

import Credit from "../components/Credit.astro";
import Contact from "../components/Contact.astro";

const commercialContactText = `We work with developers,
real estate marketing agencies
and builders internationally.
in English, Spanish and Catalan.
Tell us about your project
and we'll get back to you.`;
const commercialContactEmail = "projects@scuares.com";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- meta description for SEO-->
    <meta
      name="description"
      content="Architectural Visualization studio that produces high-end photorealistic 3D renderings for architecture and real estate. Images, Videos, 360 Virtual Tours, CG Animations, Walkthroughs, Cinemagraphs "
    />

    <!-- google site ownership verification -->
    <meta
      name="google-site-verification"
      content="Oc__Wwdl_tRXLnyFebkLVeqprhvqnJwN6DI6k9S0lB0"
    />

    <title>Scuares-Architectural Visualization. 3D Rendering</title>

    <!-- favicon -->
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />

    <!-- SCRIPTS -->

    <script>
      import "../js_commercial/app.js";
    </script>

    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=AW-807551184"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "AW-807551184");
    </script>
  </head>
  <body class="commercial-page">
    <!--=========================================
      LOGO + CONTACT BUTTON + HAMBURGER + NAV OFF SCREEN
    ===============================================-->
    <nav class="nav-commercial">
      <!-- LOGO -->
      <button
        class="nav-logo-box link"
        data-goto="#home"
        data-contact-logo
        aria-label="scroll to the top of the page"
      >
        <span class="scuares">scuares</span>
        <span class="commercial">/commercial</span>
      </button>
      <!-- RIGHT BOX -->
      <div class="nav-right-box">
        <!-- CONTACT BUTTON -->
        <button
          class="contact-btn"
          type="button"
          data-contact-toggle
          aria-controls="contact-modal"
          aria-expanded="false"
          aria-label="Open contact dialog"
        >
          <span class="contact-btn__label">contact</span>
          <span class="contact-btn__close" aria-hidden="true">
            <span></span>
            <span></span>
          </span>
        </button>

        <!-- HAMBURGER -->
        <div class="hamburger-box">
          <div class="hamburger-lines">
            <div class="line line-top"></div>
            <div class="line line-mid"></div>
            <div class="line line-bottom"></div>
          </div>
        </div>

        <button
          class="contact-modal-close"
          type="button"
          data-contact-close
          aria-label="Close contact dialog"
        >
          <span class="line-close line-close1"></span>
          <span class="line-close line-close2"></span>
        </button>
      </div>

      <!-- NAVIGATION OFF SCREEN -->
      <div class="nav-offscreen">
        <ul class="nav-links">
          <li>
            <a class="link" href="#home" aria-label="scroll to the home section"
              >Home</a
            >
          </li>
          <li>
            <a
              class="link"
              href="#about"
              aria-label="scroll to the about section">About</a
            >
          </li>
          <li>
            <a
              class="link"
              href="#films"
              aria-label="scroll to the films section">Films</a
            >
          </li>
          <li>
            <a
              class="link"
              href="#images"
              aria-label="scroll to the images section">Images</a
            >
          </li>
          <li>
            <a
              class="link"
              href="#tours"
              aria-label="scroll to the tours section">Tours</a
            >
          </li>
          <li>
            <a
              class="link contact-link"
              href="#contact-modal"
              data-contact-open
              aria-controls="contact-modal"
              aria-haspopup="dialog"
              aria-label="Open contact dialog">Contact</a
            >
          </li>
        </ul>
      </div>
    </nav>

    <main id="page-content">

    <header>
      <!--====================
      HOME
      ========================-->
      <section
        class="home section snap"
        id="home"
        data-scroll-target="#about"
      >
        <div class="cover-content" data-hero-sequence data-hero-interval="3000">
          <div class="img-hero">
            <img
              src="/images/pixel.jpg"
              data-hero-current
              alt="Photorealistic architectural visualization by Scuares"
            />

            <template data-hero-slides>
              <img
                data-src="walkeweg_b"
                data-logo="light"
                alt="Photorealistic architectural visualization by Scuares"
              />
              <img
                data-src="puglia"
                data-logo="dark"
                alt="Photorealistic architectural visualization by Scuares"
              />
              <img
                data-src="walkeweg_a"
                data-logo="light"
                alt="Photorealistic architectural visualization by Scuares"
              />
              <img
                data-src="basel_b"
                data-logo="light"
                alt="Photorealistic architectural visualization by Scuares"
              />
              <img
                data-src="basel_a"
                data-logo="light"
                alt="Photorealistic architectural visualization by Scuares"
              />
            </template>
          </div>
        </div>

        <div class="cover-text">
          <h1 class="header-main">
            <span class="header-sub">3D RENDERINGS</span><br />
            Architectural<br />
            Visualization<br />
          </h1>
          <h2 class="text-1">
            Scuares produces high quality images, animations and 360 virtul
            tours for real estate and commercial architecture.
          </h2>
        </div>
      </section>
    </header>

    <!--==============================
    ABOUT
    ===============================-->

    <section class="cover snap" id="about">
      <div class="cover-text">
        <h3 class="header-sub">ABOUT</h3>
        <h4 class="header-main">Our services.</h4>
        <p class="text-1">
          We create all types of 3d visuals to bring projects to life. <br />
          <br />
          <a
            class="about-service-link"
            href="#films"
            aria-label="Scroll to the films section">Films →</a
          ><br />
          <a
            class="about-service-link"
            href="#images"
            aria-label="Scroll to the images section">Images →</a
          ><br />
          <a
            class="about-service-link"
            href="#tours"
            aria-label="Scroll to the tours section">Tours →</a
          ><br />
        </p>
      </div>

      <div class="cover-content img-full">
        <img
          src="/images/pixel.jpg"
          data-src="walkeweg_a"
          class="img-initial"
          alt="Photorealistic exterior 3D Rendering of a real estate residential deveoplment in Gland, Switzerland. Human eye level view. Facade detail at sunset. Still CG image produced by Scuares, an architectural visualization studio"
        />
        <Credit author="Architect" project="Housing project in Gland" />
      </div>
    </section>

    <!--==============================
    FILMS
    ===============================-->
    <div class="section" id="films">
      <div class="page">
        <section class="cover snap films-main anim">
          <div class="cover-text">
            <h3 class="header-sub">FILMS</h3>
            <h4 class="header-main">
              If you can imagine it,<br />
              We can film it<br />
            </h4>
            <p class="text-1">
              Scuares produces high-end cinematic animations for all kinds of
              architectural projects or real estate properties. We create
              photorealistic 3D rendered walkthroughs, flythroughs and
              cinemagraphs. Each film is carefully crafted to visualize the
              unbuilt designs and convey the feeling of experiencing their
              spaces.
            </p>
          </div>
          <div class="cover-content">
            <video
              class="video-films"
              muted
              playsinline
              autoplay
              loop
              poster="/images/pixel.jpg"
              data-src="/videos/video_films_3mbps.mp4"
              data-poster="poster_films"
            >
              <source src="" type="video/mp4" />
            </video>
          </div>
        </section>

        <!--films-proj-->
        <section class="films-proj snap" id="films-proj">
          <!--SOLARIS-->
          <div
            class="film-item"
            data-src="https://player.vimeo.com/video/829716759?h=762c0fae3c"
            data-title="Solaris"
            data-description="3D rendered animation of an exclusive residential development in
          Switzerland.(br)
          (br)
          Developer: La Strada Properties(br)
          Architect: Justyna Gornicka - Hervé De Giovannini Architecte"
          >
            <img
              src="/images/pixel.jpg"
              data-src="film_solaris"
              class="img-lazy film-img"
              alt="Photorealistic exterior 3D Rendering of a modern contemprary villa designed by Justyna Gornicka - Hervé De Giovannini Architecte. Still CG Image produced by Scuares, an architectural visualization studio"
            />
            <div class="btn-box">
              <button class="btn-play" aria-label="play">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="svg-play"
                >
                  <path
                    fill-rule="evenodd"
                    d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z"
                    clip-rule="evenodd"></path>
                </svg>
              </button>
              <h5 class="btn-proj">Solaris<br />Film</h5>
            </div>
          </div>

          <!--VILLA-->
          <div
            class="film-item"
            data-src="https://player.vimeo.com/video/830866369?h=4a71b312ad"
            data-title="The Villa"
            data-description="A 3d rendered architectural walkthrough of a refurbished heritage villa. A video created to showcase both the spaces and the essence of the project. It includes fully computer generated scenes along with composites of drone footage and rendered animations."
          >
            <img
              src="/images/pixel.jpg"
              data-src="film_villa"
              class="img-lazy film-img"
              alt="Photorealistic exterior 3D Rendering of a traditional villa with a pool in France. Still CG image produced by Scuares, an architectural visualization studio"
            />
            <div class="btn-box">
              <button class="btn-play" aria-label="play">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="svg-play"
                >
                  <path
                    fill-rule="evenodd"
                    d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z"
                    clip-rule="evenodd"></path>
                </svg>
              </button>
              <h5 class="btn-proj">Villa<br />Film</h5>
            </div>
          </div>

          <!--VERTIGO-->
          <div
            class="film-item"
            data-src="https://player.vimeo.com/video/830818477?h=af3612985e"
            data-title="Vertigo"
            data-description="3D rendered animation of an exclusive residential development in
          Switzerland. (br)(br)
          Developer: La Strada Properties(br) 
          Architects: Justyna Gornicka - Hervé De Giovannini Architecte"
          >
            <img
              src="/images/pixel.jpg"
              data-src="film_vertigo"
              class="img-lazy film-img"
              alt="Photorealistic exteriorn 3D Rendering of a modern housing complex in Switzerland designed by Hervé DeGiovannini Architecte. With contemporary metal facade design. Still CG Image produced by Scuares, an architectural visualization studio"
            />
            <div class="btn-box">
              <button class="btn-play" aria-label="play">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="svg-play"
                >
                  <path
                    fill-rule="evenodd"
                    d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z"
                    clip-rule="evenodd"></path>
                </svg>
              </button>
              <h5 class="btn-proj">Vertigo<br />Film</h5>
            </div>
          </div>
        </section>
      </div>
    </div>

    <!-- Film modal -->
    <div class="film-modals">
      <div
        class="modal-film"
        role="dialog"
        aria-modal="true"
        aria-labelledby="film-modal-title"
        hidden
      >
        <div class="modal-container">
          <div class="modal-video" data-film-player></div>

          <div class="modal-text">
            <h4 id="film-modal-title" class="modal-title header-main"></h4>
            <p class="modal-description text-1"></p>
          </div>
        </div>

        <button class="modal-close" type="button" aria-label="Close film">
          <span class="line-close line-close1"></span>
          <span class="line-close line-close2"></span>
        </button>
      </div>

      <div class="film-player-cache" hidden aria-hidden="true"></div>
    </div>
    <!--==============================
      IMAGES
     ==============================-->
    <div class="section" id="images">
      <section class="images cover snap">
        <div class="cover-text">
          <h3 class="header-sub">IMAGES</h3>
          <h4 class="header-main">
            We take photos<br />
            of the unbuilt<br />
          </h4>
          <p class="text-1">
            We create striking 3D rendered still images of your projects,
            visualizing unbuilt architecture and design as if it had already
            been created. Our renderings are virtual photographs, developed to
            portray buildings and spaces in the most photorealistic manner.
          </p>
        </div>
        <div class="cover-content img-full">
          <img
            src="/images/pixel.jpg"
            data-src="gym"
            class="img-lazy"
            alt="Photorealistic exterior 3D Rendering of a wooden sports complex designed by Transversal Architects and Acte architects. Contemporary facade design. Still CG Image produced by Scuares, an architectural visualization studio"
          />
          <Credit
            author="Transversal + Acte Arch."
            project="Sports Complex in St. Maurice"
          />
        </div>
      </section>

      <!-- IMAGES SLIDES -->

      <!-- washington -->
      <section class="images-two snap">
        <div class="img-pad">
          <img
            src="/images/pixel.jpg"
            data-src="washington_aerial"
            width="1162"
            height="1000"
            style="aspect-ratio: 1162 / 1000"
            class="img-lazy"
            alt="Aerial photorealistic exterior 3D Rendering of a modern multifunctional complex in an urban context in Washington. Still CG image produced by Scuares, an architectural visualization studio"
          />
          <Credit
            author="Partnership with Pictury"
            project="Multifunctional Building"
          />
        </div>
        <div class="img-pad">
          <img
            src="/images/pixel.jpg"
            data-src="washington_street"
            width="1000"
            height="1018"
            style="aspect-ratio: 1000 / 1018"
            class="img-lazy img-cover img-square"
            alt="Photorealistic exterior 3D Rendering of a modern multifunctional complex in an urban context in Washington. View from a human eye level. Still CG image produced by Scuares, an architectural visualization studio"
          />
          <Credit
            hidden={true}
            author="Partnership with Pictury"
            project="Multifunctional Building"
          />
        </div>
      </section>

      <!-- bedroom - dining -->
      <section class="images-two snap">
        <div class="img-full">
          <img
            src="/images/pixel.jpg"
            data-src="bedroom"
            width="1000"
            height="1000"
            style="aspect-ratio: 1 / 1"
            class="img-lazy"
            alt="Photorealistic interior 3D Rendering of a modern dining room in an apartment in Berlin, designed by JM Designs. Mix of contemporary furniture with classical architecture. Real Estate residential project. Still CG Image produced by Scuares, an architectural visualization studio"
          />
          <Credit author="JM Designs" project="Apartment in Berlin" />
        </div>
        <div class="img-pad">
          <img
            src="/images/pixel.jpg"
            data-src="dining"
            width="1000"
            height="1175"
            style="aspect-ratio: 1000 / 1175"
            class="img-lazy"
            alt="Photorealistic interior 3D Rendering of a modern bedroom in an apartment in Berlin, designed by JM Designs. Mix of contemporary furniture with classical architecture.Real Estate residential project. Still CG Image produced by Scuares, an architectural visualization studio"
          />
          <Credit hidden={true} author="JM Designs" project="Apartment in Berlin" />
        </div>
      </section>

      <!-- puglia -->
      <section class="images-one snap">
        <div class="img-pad">
          <img
            src="/images/pixel.jpg"
            data-src="puglia"
            width="1778"
            height="1000"
            style="aspect-ratio: 1778 / 1000"
            class="img-lazy"
            alt="Photorealistic exterior 3D Rendering of a modern house in a beautiful landscape in Puglia designed by Bergnes de las Casas Arquitectos. Contemporary facade design with concrete and wood. Still CG Image produced by Scuares, an architectural visualization studio"
          />
          <Credit author="Bergnes de las Casas" project="Villa in Puglia" />
        </div>
      </section>

      <!-- walkeweg -->
      <section class="images-two snap">
        <div class="img-full">
          <img
            src="/images/pixel.jpg"
            data-src="walkeweg_a"
            width="1000"
            height="1250"
            style="aspect-ratio: 1000 / 1250"
            class="img-lazy"
            alt="Photorealistic exterior 3D Rendering of a modern housing complex in Walkeweg, designed by Parabase Architects. First prize in an architectural competition. Building made of recycled concrete components. Still CG Image produced by Scuares, an architectural visualization studio"
          />
          <Credit author="Parabase" project="Areal Walkeweg Nord Basel" />
        </div>

        <div class="img-pad">
          <img
            src="/images/pixel.jpg"
            data-src="walkeweg_b"
