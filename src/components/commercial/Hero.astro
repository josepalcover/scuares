---
import PictureHero from "../shared/PictureHero.astro";

interface Props {
  slides: Array<{ src: string; alt: string; logoTheme: string }>;
}

const { slides: heroSlides } = Astro.props;
const [initialSlide] = heroSlides;
---

<!--====================
  HOME
========================-->
<header>
  <section class="home section snap" id="home" data-scroll-target="#about">
    <div class="cover-content" data-hero-sequence data-hero-interval="3000">
      <div class="img-hero">
        <PictureHero
          src={initialSlide.src}
          alt={initialSlide.alt}
          loading="eager"
          decoding="async"
          fetchpriority="high"
          pictureAttributes={{
            "data-hero-current": "",
            "data-logo": initialSlide.logoTheme,
          }}
        />

        <template data-hero-slides>
          {
            heroSlides.map((slide) => (
              <PictureHero
                src={slide.src}
                alt={slide.alt}
                pictureAttributes={{
                  "data-hero-slide": "",
                  "data-logo": slide.logoTheme,
                }}
              />
            ))
          }
        </template>
      </div>
    </div>

    <div class="cover-text">
      <h1 class="header-main">
        <span class="header-sub">3D RENDERINGS</span><br />
        Architectural<br />
        Visualization<br />
      </h1>
      <h2 class="text-1">
        Scuares produces high quality images, animations and 360 virtul tours
        for real estate and commercial architecture.
      </h2>
    </div>
  </section>
</header>
