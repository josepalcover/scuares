---
import ContactBase from "../shared/ContactBase.astro";

interface Props {
  variant?: "inline" | "modal";
}

const { variant = "inline" } = Astro.props;
const contact = {
  heading: "Get in\ntouch.",
  text: `We work with developers,
real estate marketing agencies
and builders internationally.
in English, Spanish and Catalan.
Tell us about your project
and we'll get back to you.`,
  email: "projects@scuares.com",
  instagramLabel: "instagram",
  instagramHandle: "@scuares.studio",
  instagramUrl: "https://instagram.com/scuares.studio",
};
---

<ContactBase variant={variant} {...contact} />
