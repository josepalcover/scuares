<!--==============================
  IMAGES
===============================-->
<div class="section" id="images">
  <section class="images cover snap">
    <div class="cover-text">
      <h3 class="header-sub">IMAGES</h3>
      <h4 class="header-main">
        We take photos<br />
        of the unbuilt<br />
      </h4>
      <p class="text-1">
        We create striking 3D rendered still images of your projects,
        visualizing unbuilt architecture and design as if it had already been
        created. Our renderings are virtual photographs, developed to portray
        buildings and spaces in the most photorealistic manner.
      </p>
    </div>
    <div class="cover-content img-full">
      <PictureGallery
        src={gym}
        alt="Photorealistic exterior 3D Rendering of a wooden sports complex designed by Transversal Architects and Acte architects. Contemporary facade design. Still CG Image produced by Scuares, an architectural visualization studio"
      />
      <Credit
        author="Transversal + Acte Arch."
        project="Sports Complex in St. Maurice"
      />
    </div>
  </section>

  {
    gallerySlides.map((slide) => (
      <section class={slide.className}>
        {slide.items.map((item) => (
          <div class={item.wrapperClass}>
            <PictureGallery src={item.src} alt={item.alt} />
            <Credit
              author={item.author}
              project={item.project}
              hidden={item.creditHidden}
            />
          </div>
        ))}
      </section>
    ))
  }
</div>
