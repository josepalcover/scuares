---
import PictureHero from "./PictureHero.astro";
import { HERO_ALT, HERO_SLIDES } from "../config/heroSlides.js";

const [initialSlide] = HERO_SLIDES;
---

<!--==============================
  HERO - HOME
 ==============================-->
<section
  class="hero-full snap"
  data-logo="dark"
  data-contact="dark"
  data-scroll-target="#about"
  data-hero-sequence
  data-hero-interval="3000"
  id="home"
>
  <div class="logo-hero" data-hero-logo>scuares</div>
  <div class="img-hero">
    <PictureHero
      src={initialSlide.src}
      alt={HERO_ALT}
      loading="eager"
      decoding="async"
      fetchpriority="high"
      pictureAttributes={{
        "data-hero-current": "",
        "data-logo": initialSlide.logoTheme,
      }}
    />

    <template data-hero-slides>
      {
        HERO_SLIDES.map((slide) => (
          <PictureHero
            src={slide.src}
            alt={HERO_ALT}
            pictureAttributes={{
              "data-hero-slide": "",
              "data-logo": slide.logoTheme,
            }}
          />
        ))
      }
    </template>
  </div>
</section>
