---
interface Props {
  variant?: "inline" | "modal";
}

const { variant = "inline" } = Astro.props;
const isModal = variant === "modal";
const copyStatusId = `email-copy-status-${variant}`;
---

<section
  class:list={["images-one", { snap: !isModal, "contact-modal": isModal }]}
  id={isModal ? "contact-modal" : "contact"}
  data-contact-instance
  data-logo={isModal ? undefined : "dark"}
  data-contact={isModal ? undefined : "dark"}
  role={isModal ? "dialog" : undefined}
  aria-modal={isModal ? "true" : undefined}
  aria-label={isModal ? "Contact" : undefined}
  aria-hidden={isModal ? "true" : undefined}
  inert={isModal ? true : undefined}
>
  <div class="centered-box">
    <div class="text-box">
      <!-- 
      <h3 class="header-main">
        Get in<br />
        touch.
      </h3>
      -->
      <p class="text-normal">
        Get in<br />
        touch.<br />
        <br />
        We work with architects worldwide,<br />
        in English, Spanish and Catalan.<br />
        <br />
        Tell us about your project,<br />
        we'll get back to you.<br />
        <br />
        <br />
        <button
          class="email"
          type="button"
          data-email="info@scuares.com"
          data-email-copy
          aria-describedby={copyStatusId}>info@scuares.com</button
        >
        <span
          id={copyStatusId}
          class="email-copy-status"
          data-email-copy-status
          aria-live="polite"
          hidden>[email copied]</span
        >
      </p>
    </div>
  </div>
</section>

<script>
  document
    .querySelectorAll<HTMLButtonElement>("[data-email-copy]")
    .forEach((emailButton) => {
      let hideCopyStatusTimeout: ReturnType<typeof setTimeout>;

      emailButton.addEventListener("click", async () => {
        const email = emailButton.dataset.email;
        const contact = emailButton.closest("[data-contact-instance]");
        const copyStatus = contact?.querySelector<HTMLElement>(
          "[data-email-copy-status]",
        );

        if (!email || !copyStatus) return;

        await navigator.clipboard.writeText(email);
        copyStatus.hidden = false;

        clearTimeout(hideCopyStatusTimeout);
        hideCopyStatusTimeout = setTimeout(() => {
          copyStatus.hidden = true;
        }, 3000);
      });
    });
</script>
