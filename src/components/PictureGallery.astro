---
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";
import {
  GALLERY_SIZES,
  PICTURE_FALLBACK_FORMAT,
  PICTURE_FORMATS,
  PICTURE_QUALITY,
  PICTURE_WIDTHS,
} from "../config/pictures.js";

interface Props {
  src: ImageMetadata;
  alt: string;
  class?: string;
  loading?: "eager" | "lazy";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
  priority?: boolean;
  pictureAttributes?: Record<string, unknown>;
}

const {
  src,
  alt,
  class: className,
  loading = "lazy",
  decoding = "async",
  fetchpriority,
  priority,
  pictureAttributes,
} = Astro.props;
---

<Picture
  src={src}
  alt={alt}
  class={className}
  data-gallery-image=""
  formats={PICTURE_FORMATS}
  fallbackFormat={PICTURE_FALLBACK_FORMAT}
  widths={PICTURE_WIDTHS}
  sizes={GALLERY_SIZES}
  quality={PICTURE_QUALITY}
  loading={loading}
  decoding={decoding}
  fetchpriority={fetchpriority}
  priority={priority}
  pictureAttributes={{
    ...pictureAttributes,
    "data-gallery-picture": "",
  }}
/>
