---
import PictureHero from "../shared/PictureHero.astro";
---

<!--==============================
  HERO - HOME
 ==============================-->
<section
  class="hero-full snap"
  data-logo="dark"
  data-contact="dark"
  data-scroll-target="#about"
  data-hero-sequence
  data-hero-interval="3000"
  id="home"
>
  <div class="logo-hero" data-hero-logo>scuares</div>
  <div class="img-hero">
    <PictureHero
      src="walkeweg_b"
      alt="Photorealistic architectural visualization by Scuares"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      pictureAttributes={{
        "data-hero-current": "",
        "data-logo": "light",
      }}
    />

    <template data-hero-slides>
      <PictureHero
        src="walkeweg_b"
        alt="Photorealistic architectural visualization by Scuares"
        pictureAttributes={{
          "data-hero-slide": "",
          "data-logo": "light",
        }}
      />
      <PictureHero
        src="puglia"
        alt="Photorealistic architectural visualization by Scuares"
        pictureAttributes={{
          "data-hero-slide": "",
          "data-logo": "dark",
        }}
      />
      <PictureHero
        src="walkeweg_a"
        alt="Photorealistic architectural visualization by Scuares"
        pictureAttributes={{
          "data-hero-slide": "",
          "data-logo": "light",
        }}
      />
      <PictureHero
        src="basel_b"
        alt="Photorealistic architectural visualization by Scuares"
        pictureAttributes={{
          "data-hero-slide": "",
          "data-logo": "light",
        }}
      />
      <PictureHero
        src="basel_a"
        alt="Photorealistic architectural visualization by Scuares"
        pictureAttributes={{
          "data-hero-slide": "",
          "data-logo": "light",
        }}
      />
    </template>
  </div>
</section>
