---
import PictureHero from "../shared/PictureHero.astro";

interface Props {
  slides: Array<{ src: string; alt: string; logoTheme: string }>;
}

const { slides: heroSlides } = Astro.props;
const [initialSlide] = heroSlides;
---

<!--==============================
  HERO - HOME
 ==============================-->
<section
  class="hero-full snap"
  data-logo="dark"
  data-contact="dark"
  data-scroll-target="#about"
  data-hero-sequence
  data-hero-interval="3000"
  id="home"
>
  <div class="logo-hero" data-hero-logo>scuares</div>
  <div class="img-hero">
    <PictureHero
      src={initialSlide.src}
      alt={initialSlide.alt}
      loading="eager"
      decoding="async"
      fetchpriority="high"
      pictureAttributes={{
        "data-hero-current": "",
        "data-logo": initialSlide.logoTheme,
      }}
    />

    <template data-hero-slides>
      {
        heroSlides.map((slide) => (
          <PictureHero
            src={slide.src}
            alt={slide.alt}
            pictureAttributes={{
              "data-hero-slide": "",
              "data-logo": slide.logoTheme,
            }}
          />
        ))
      }
    </template>
  </div>
</section>
